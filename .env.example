# Telegram Bot 配置
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
OWNER_CHAT_ID=123456789

# 公开域名（必须配置，用于图床链接）
PUBLIC_BASE_URL=https://your-bot-domain.com

# Web 服务端口
WEB_PORT=8080

# WebDAV 备份配置（可选，留空则禁用备份功能）
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=

# 自动备份间隔（小时，设置为 0 关闭自动备份）
BACKUP_INTERVAL_HOURS=24